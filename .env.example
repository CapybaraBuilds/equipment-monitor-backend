# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=your_pg_user
PG_PASSWORD=your_pg_password
PG_DATABASE=your_pg_database
 
# MongoDB
MONGODB_URI=mongodb://your_mongo_user:your_mongo_password@localhost:27017/your_database?authSource=admin
 
# RabbitMQ
RABBITMQ_URI=amqp://your_rabbitmq_user:your_rabbitmq_password@localhost:5672
 
# App
PORT=3001
NODE_ENV=development